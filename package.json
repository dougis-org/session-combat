{
  "name": "session-combat",
  "version": "1.0.0",
  "description": "holds a combat tracker and encounters for a single DnD session",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/generate-version.js && next dev",
    "build": "node scripts/generate-version.js && next build",
    "start": "BUILD_VERSION=$(node -e \"console.log(require('./package.json').version)\") BUILD_TIME=$(date -u +'%Y-%m-%dT%H:%M:%SZ') HOSTNAME=0.0.0.0 PORT=3000 next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "coverage:e2e:merge": "node scripts/merge-playwright-coverage.mjs",
    "test:unit": "jest --testPathPattern='tests/unit' --coverage",
    "test:integration": "jest --config=jest.integration.config.js",
    "test:docker": "jest --config=jest.docker.config.js",
    "test:ci": "npm run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "npm run build && PLAYWRIGHT_COVERAGE=true PLAYWRIGHT_SERVER_MODE=production CHROMIUM_ONLY=1 playwright test tests/e2e/ && npm run coverage:e2e:merge",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "opsx:init-change": "sh scripts/init-change.sh",
    "prepare": "husky install",
    "test:regression": "playwright test tests/e2e/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "fuse.js": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@swc/helpers": "0.5.19",
    "@swc/jest": "^0.2.29",
    "@tailwindcss/postcss": "^4.1.18",
    "@testcontainers/mongodb": "^10.3.1",
    "@testcontainers/postgresql": "^10.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^25.0.2",
    "@types/node-fetch": "^2.6.9",
    "@types/pg": "^8.10.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "uuid": "^9.0.1",
    "v8-to-istanbul": "^9.3.0"
  }
}